{
  "name": "llm-chat-interface",
  "version": "1.0.0",
  "description": "A web-based chat interface with AI capabilities, voice interaction, image generation, and enhanced reasoning through Model Context Protocol (MCP) integration.",
  "main": "src/main.tsx",
  "type": "module",
  "scripts": {
    "start": "vite --host 127.0.0.1",
    "start:both": "node src/server/start-servers.js",
    "start:http": "node src/server/mcp-http-server.js",
    "start:mcp": "node src/server/mcp-server.js",
    "dev": "vite --host 127.0.0.1",
    "dev:http": "node --watch src/server/mcp-http-server.js",
    "dev:mcp": "node --watch src/server/mcp-server.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@modelcontextprotocol/sdk": "^0.4.0",
    "@mozilla/readability": "^0.6.0",
    "@vitejs/plugin-react": "^6.0.2",
    "axios": "^1.9.0",
    "cheerio": "^1.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "http-proxy": "^1.18.1",
    "jsdom": "^26.1.0",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.5",
    "motion": "^12.40.0",
    "node-fetch": "^3.3.2",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "turndown": "^7.2.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "live-server": "^1.2.0"
  },
  "keywords": [
    "chat",
    "llm",
    "image generation",
    "roleplaying",
    "mcp",
    "model-context-protocol",
    "sequential-thinking",
    "reasoning",
    "ai"
  ],
  "author": "Your Name",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
